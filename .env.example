# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Optional: override the AI provider base URL (default: Cerebras)
# Cerebras options: gpt-oss-120b, llama3.1-8b
AI_BASE_URL=https://api.cerebras.ai/v1
AI_MODEL=qwen-3-235b-a22b-instruct-2507
AI_API_KEY=

# Storage — pick at most ONE backend. If both are set, Upstash wins.
# When neither is set, the bot runs in stateless mode (no memory, no
# rate limit, no provider preferences, no search cache, no dedupe).
#
# Option A — Upstash Redis (works on Vercel and other hosts with
# unrestricted outbound HTTPS). Get these from https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Option B — Local SQLite (works on hosts with persistent disk like
# PythonAnywhere; does NOT work on Vercel — each invocation gets a
# fresh filesystem). ~100x faster per op than Upstash REST because
# the DB lives in-process. Set to an absolute path the worker can
# write to. The file is created if it doesn't exist.
# SQLITE_PATH=/home/<your-pa-username>/bot.db

# Optional: Tavily API key for web search
# TAVILY_API_KEY=

# Optional: Hugging Face Gradio Space — enables the /model command
# HF_SPACE_ID=edisimon/armgpt-demo
# HF_TOKEN=

# Optional: random secret to verify webhook requests come from Telegram (recommended)
# Generate one with: openssl rand -hex 16
# WEBHOOK_SECRET=

# Optional: your Vercel production URL — only used by `make push`
# PROD_URL=
